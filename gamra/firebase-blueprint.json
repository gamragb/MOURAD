{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Inventory product item",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "buyPrice": { "type": "number" },
        "sellPrice": { "type": "number" },
        "qty": { "type": "number" },
        "minQty": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "buyPrice", "sellPrice", "qty"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "debt": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Supplier details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "debt": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Sales record",
      "type": "object",
      "properties": {
        "invoiceNo": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "total": { "type": "number" },
        "items": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "staffId": { "type": "string" }
      },
      "required": ["invoiceNo", "total", "items", "createdAt"]
    },
    "Purchase": {
      "title": "Purchase",
      "description": "Purchase record from supplier",
      "type": "object",
      "properties": {
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["supplierId", "total", "items", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "App user profile and role",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "enum": ["admin", "staff"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/products": { "schema": "Product", "description": "Inventory list" },
    "/categories": { "schema": "Category", "description": "Product categories" },
    "/customers": { "schema": "Customer", "description": "Customer list" },
    "/suppliers": { "schema": "Supplier", "description": "Supplier list" },
    "/sales": { "schema": "Sale", "description": "Sales history" },
    "/purchases": { "schema": "Purchase", "description": "Purchase history" },
    "/users": { "schema": "UserProfile", "description": "User profiles and roles" },
    "/settings/pos": { "schema": "object", "description": "POS settings like last invoice number" }
  }
}
