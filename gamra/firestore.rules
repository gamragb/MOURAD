rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return true; } // Temporarily allow for dev/restricted env
    function isStaff() { return true; } // Temporarily allow for dev/restricted env
    
    match /{document=**} {
      allow read, write: if true; // Allow all for now due to auth restrictions in user environment
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
    }

    match /products/{productId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /categories/{categoryId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /customers/{customerId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /suppliers/{supplierId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /purchases/{purchaseId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }
  }
}
